{
  "name": "@sadcoderlabs/laughing-man",
  "version": "0.1.0",
  "description": "Turn your Markdown into a newsletter",
  "type": "module",
  "files": [
    "dist"
  ],
  "exports": {
    ".": "./dist/src/cli.js"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sadcoderlabs/laughing-man.git"
  },
  "keywords": [
    "newsletter",
    "markdown",
    "email",
    "cli",
    "cloudflare-pages",
    "resend"
  ],
  "bin": {
    "laughing-man": "dist/src/cli.js"
  },
  "scripts": {
    "build": "tsc --project tsconfig.build.json && cp themes/default/*.css themes/default/*.svg themes/default/*.png dist/themes/default/ && mkdir -p dist/skills/laughing-man && cp skills/laughing-man/SKILL.md dist/skills/laughing-man/",
    "prepublishOnly": "bun run build",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@11ty/gray-matter": "2.0.1",
    "cloudflare": "5.2.0",
    "marked": "17.0.5",
    "mjml": "4.18.0",
    "resend": "6.9.4",
    "yaml": "2.8.3",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "4.20260317.1",
    "@types/bun": "1.3.11",
    "@types/mjml": "4.7.4",
    "@types/node": "25.5.0",
    "typescript": "6.0.2"
  },
  "peerDependencies": {
    "wrangler": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "wrangler": {
      "optional": true
    }
  }
}
