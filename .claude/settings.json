{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/ensure-build.sh\"",
            "timeout": 30,
            "statusMessage": "Building dist/..."
          }
        ]
      }
    ]
  }
}
